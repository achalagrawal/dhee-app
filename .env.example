# Convex deployment URL — auto-filled by `pnpm convex:dev` on first run.
EXPO_PUBLIC_CONVEX_URL=

# Set these in the Convex dashboard (Settings → Environment Variables),
# not in this file. Listed here for discoverability.
#
#   ANTHROPIC_API_KEY   Anthropic API key used by the agent
#   MD_MCP_URL          MD MCP endpoint (default https://md-mcp.achal.xyz/mcp)
