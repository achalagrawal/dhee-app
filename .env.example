# Convex deployment URL — auto-filled by `pnpm convex:dev` on first run.
EXPO_PUBLIC_CONVEX_URL=

# Everything below is set in the Convex deployment, not in this file:
#   npx convex env set NAME value
#
# Models (via OpenRouter)
#   OPENROUTER_API_KEY      Key from https://openrouter.ai/keys
#
# Sign-in email (via AWS SES)
#   AWS_REGION              SES region, e.g. ap-south-1
#   AWS_ACCESS_KEY_ID       IAM key with ses:SendEmail
#   AWS_SECRET_ACCESS_KEY   Matching secret
#   AWS_SESSION_TOKEN       Only if using temporary credentials
#   AUTH_EMAIL_FROM         Sender, must be a verified SES identity
#
# Auth
#   JWT_PRIVATE_KEY, JWKS   Token signing keypair
#   SITE_URL                Base URL for auth links
#
# Retrieval
#   MD_MCP_URL              Optional; defaults to the hosted MD MCP server
